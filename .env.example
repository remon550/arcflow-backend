PORT=3001
ARC_RPC_URL=https://rpc.testnet.arc.network
USDC_CONTRACT=0x3600000000000000000000000000000000000000
FRONTEND_URL=https://arcflow.live
NODE_ENV=development
DB_PATH=./arcflow.db

# ── Supabase (get from Supabase Dashboard → Settings → API) ──────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhb...         # service_role key — NEVER expose to frontend
SUPABASE_ANON=eyJhb...               # anon key — injected into leaderboard.html by inject-config.js

# ── Supabase Management API (Dashboard → Account → Access Tokens) ─────────────
# Used once by setup.sh to apply supabase/schema.sql. Not needed at runtime.
SUPABASE_ACCESS_TOKEN=sbp_YOUR_TOKEN_HERE

# ── First admin ───────────────────────────────────────────────────────────────
# Your 0x wallet address. Gets is_admin=TRUE after your first sign-in.
ADMIN_WALLET=0xYOUR_WALLET_HERE
